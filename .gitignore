# Root ignore rules for the monorepo

# Node / Next
node_modules/
**/node_modules/
.next/
**/.next/
out/
**/out/

# Python
.venv/
**/.venv/
__pycache__/
**/__pycache__/
*.py[cod]
.pytest_cache/

# Logs
*.log

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Environment files (keep templates)
.env
.env.*
!.env.example
!**/.env.example

# Credentials / secrets
serviceAccountKey.json
**/serviceAccountKey.json
*firebase-adminsdk-*.json
**/*firebase-adminsdk-*.json
promptwar-*-firebase-adminsdk-*.json

# Firebase local artifacts
.webpack/

# Build artifacts
build/
**/build/
dist/
**/dist/
