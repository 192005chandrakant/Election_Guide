# CivicGuide Agent Service — Environment Variables
# Copy this file to .env and fill in your actual keys

# ─── Required ───
# Get your Gemini API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Optional: Firebase Admin (for server-side Firestore access) ───
# Download your service account JSON from Firebase Console > Project Settings > Service Accounts
# FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# ─── Optional: Production CORS ───
# Restrict to your deployed Next.js URL in production
# ALLOWED_ORIGIN=https://your-app.vercel.app

# ─── Server ───
PORT=8000
HOST=0.0.0.0
